{
  "name": "sirius-gateway",
  "private": true,
  "version": "0.1.0",
  "description": "Unified AI Gateway — OpenAI-compatible API for multiple providers",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "bun --watch apps/sirius-api/src/main.ts",
    "start": "bun apps/sirius-api/src/main.ts",
    "build": "bun build apps/sirius-api/src/main.ts --outdir dist --target bun",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint \"{apps,libs}/**/src/**/*.ts\"",
    "format": "bunx prettier --write \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@types/bun": "^1.3.11",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@nova/contracts": "file:../nova/packages/contracts",
    "@nova/mcp-shared": "file:../nova/packages/mcp-shared",
    "zod": "^4.3.6"
  }
}
