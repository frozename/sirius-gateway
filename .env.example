# Sirius Gateway Configuration

# Server
SIRIUS_PORT=3000
SIRIUS_HOST=0.0.0.0
SIRIUS_LOG_LEVEL=debug

# Authentication (comma-separated API keys)
SIRIUS_API_KEYS=sk-sirius-dev-key

# OpenAI Provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Anthropic Provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama Provider
OLLAMA_BASE_URL=http://localhost:11434

# Routing
SIRIUS_DEFAULT_STRATEGY=pinned
SIRIUS_DEFAULT_MODEL=gpt-4o

# Policy
SIRIUS_RETRY_MAX_ATTEMPTS=2
SIRIUS_RETRY_BASE_DELAY_MS=500
SIRIUS_TIMEOUT_MS=60000
SIRIUS_CIRCUIT_BREAKER_THRESHOLD=5
SIRIUS_CIRCUIT_BREAKER_RESET_MS=30000

# CORS
SIRIUS_CORS_ORIGIN=*
